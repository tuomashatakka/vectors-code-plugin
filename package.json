{
  "name": "@tuomashatakka/vectors-plugin",
  "version": "0.2.0",
  "type": "module",
  "description": "Global, local, project-partitioned semantic RAG: a vector-index skill plus an MCP server with per-project and cross-project (global) search. TypeScript on Bun, backed by Postgres + pgvector.",
  "homepage": "https://github.com/tuomashatakka/vectors-code-plugin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuomashatakka/vectors-code-plugin.git"
  },
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "src",
    "hooks",
    "assets",
    "commands",
    "scripts",
    "references",
    "setup.sh",
    "spec.md",
    ".mcp.json"
  ],
  "engines": {
    "node": ">=24",
    "bun": ">=1.2"
  },
  "bin": {
    "vectors": "src/cli/index.ts"
  },
  "scripts": {
    "setup": "bun src/cli/index.ts setup",
    "wire": "bash setup.sh",
    "unwire": "bash setup.sh --uninstall",
    "demo-viewer": "bun src/viewer/make_demo.ts",
    "lint": "eslint src hooks eslint.config.mjs",
    "lint:fix": "eslint src hooks eslint.config.mjs --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@opentui/core": "^0.4.2",
    "@xenova/transformers": "^2.17.2",
    "ml-pca": "^4.1.1",
    "pg": "^8.13.1",
    "tree-sitter-wasms": "^0.1.11",
    "web-tree-sitter": "^0.25.1"
  },
  "devDependencies": {
    "@tuomashatakka/eslint-config": "^3.2.2",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.10",
    "bun-types": "^1.3.14",
    "eslint": "^9.39.0"
  },
  "trustedDependencies": [
    "protobufjs"
  ]
}

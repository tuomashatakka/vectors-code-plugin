# vectors daemon — configuration.
# Copy to `ukdb-daemon.env` and edit, then run `bash install.sh`.
# Every line is KEY=VALUE; these become the daemon's environment.
# Canonical names are VINDEX_*; the legacy UKDB_* forms are still read as aliases.

# --- required ---------------------------------------------------------------
# libpq DSN to the unified DB (must already have the schema from
# references/unified-knowledge-db.sql applied, with pgvector installed).
VINDEX_DSN=postgres://localhost:5432/vectors

# --- models -----------------------------------------------------------------
# sentence-transformers model (must match what you index with elsewhere).
VINDEX_EMBED_MODEL=all-MiniLM-L6-v2
# Local Ollama for the "haiku-level" digest tasks (summaries, fact extraction).
VINDEX_OLLAMA_URL=http://localhost:11434
VINDEX_OLLAMA_MODEL=llama3.1:8b

# --- feeders ----------------------------------------------------------------
# ','-separated globs of session-history files to mirror. Default covers Claude
# Code transcripts (incl. nested subagents/) and the global prompt history.
VINDEX_CHAT_GLOBS=~/.claude/projects/**/*.jsonl,~/.claude/history.jsonl

# --- cadence (seconds) --------------------------------------------------------
# Chat feeder sweep interval.
VINDEX_CHAT_INTERVAL=5
# Source (project re-ingest) sweep interval.
VINDEX_SOURCE_INTERVAL=300

# Remote backup (VINDEX_BACKUP_PROVIDER et al.) is roadmap, not read yet —
# see the README's Roadmap section. Until then: pg_dump/pg_restore manually.

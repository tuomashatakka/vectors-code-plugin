# Unified Knowledge Database daemon — configuration.
# Copy to `ukdb-daemon.env` and edit, then run `bash install.sh`.
# Every line is KEY=VALUE; these become the daemon's environment.

# --- required ---------------------------------------------------------------
# libpq DSN to the unified DB (must already have the schema from
# references/unified-knowledge-db.sql applied, with pgvector installed).
UKDB_DSN=postgresql:///ukdb

# --- models -----------------------------------------------------------------
# sentence-transformers model (must match what you index with elsewhere).
UKDB_EMBED_MODEL=all-MiniLM-L6-v2
# Local Ollama for the "haiku-level" digest tasks (summaries, fact extraction).
UKDB_OLLAMA_URL=http://localhost:11434
UKDB_OLLAMA_MODEL=llama3.1:8b

# --- feeders ----------------------------------------------------------------
# ';'-separated globs of chat transcript files to ingest (Claude Code default).
UKDB_CHAT_GLOBS=~/.claude/projects/**/*.jsonl
# Existing vector-index store to mirror file sources from.
UKDB_VINDEX_HOME=~/.local/share/vector-index

# --- cadence ----------------------------------------------------------------
UKDB_POLL_INTERVAL=5
UKDB_FEEDER_INTERVAL=900
UKDB_BATCH=32
# Set to 1 to run the job worker only (no chat/source feeders).
UKDB_DISABLE_FEEDERS=0

# --- optional remote backup (off unless UKDB_BACKUP_PROVIDER is set) ---------
# pg_dump of the whole DB, pushed to one or more providers ~once a day.
# Comma-separated; any of: folder, rclone, obsidian, notion.
#UKDB_BACKUP_PROVIDER=folder
#UKDB_BACKUP_INTERVAL=86400     # seconds between backups (default daily)
#UKDB_BACKUP_RETENTION=7        # keep the newest N dumps (folder/obsidian/rclone)
#UKDB_PG_DUMP=pg_dump           # path to pg_dump if not on PATH

# provider: folder — copy into any local dir. Point it at a OneDrive or Google
# Drive *local sync folder* (e.g. ~/Library/CloudStorage/OneDrive-Personal/...)
# to back up to those clouds with zero API setup.
#UKDB_BACKUP_DIR=~/Library/CloudStorage/OneDrive-Personal/ukdb-backups

# provider: rclone — true cloud upload via a configured rclone remote (covers
# OneDrive, Google Drive, etc.). Run `rclone config` once to create the remote.
#UKDB_RCLONE_REMOTE=onedrive:backups/ukdb
#UKDB_RCLONE_BIN=rclone

# provider: obsidian — copy the dump into a vault subfolder and keep an index
# note ("UKDB Backups.md"). Use Obsidian Sync / iCloud to mirror it remotely.
#UKDB_OBSIDIAN_VAULT=~/Documents/MyVault
#UKDB_OBSIDIAN_SUBDIR=ukdb-backups

# provider: notion — write a backup manifest entry (timestamp/size/checksum/
# location) as a child page. The dump bytes go to the byte-storing providers
# above; Notion is the searchable catalog. UKDB_NOTION_PARENT is a page id.
#UKDB_NOTION_TOKEN=secret_xxx
#UKDB_NOTION_PARENT=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
